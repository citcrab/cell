                            <text x="100" y="50" text-anchor="middle" font-size="9" fill="#198754">Balloon (membrane)</text>
                            <text x="100" y="170" text-anchor="middle" font-size="8" fill="#198754">⬅️ Box (wall) prevents bursting</text>

                            <circle cx="280" cy="90" r="55" fill="#f2faf5" stroke="#b34a4a" stroke-width="2">
                                <animate attributeName="r" values="55;65;55" dur="1.8s" repeatCount="indefinite" />
                            </circle>
