        const quizData = [{
            q: 'Who discovered the nucleus?',
            options: ['Robert Hooke', 'Anton van Leeuwenhoek', 'Robert Brown', 'Schleiden'],
            correct: 2,
            explanation: 'Robert Brown discovered the nucleus in 1831.'
        }, {
            q: 'What is the function of the cell wall in plants?',
            options: ['Selective permeability', 'Energy production', 'Rigid support and protection', 'Protein synthesis'],
            correct: 2,
            explanation: 'The cell wall provides rigid support and protection, made of cellulose.'
        }, {
            q: 'Which organelle is called the "powerhouse of the cell"?',
            options: ['Golgi apparatus', 'Mitochondria', 'ER', 'Lysosomes'],
            correct: 1,
            explanation: 'Mitochondria produce ATP energy and are called the powerhouse.'
        }, {
            q: 'What is the main difference between prokaryotic and eukaryotic cells?',
            options: ['Size only', 'Presence of a true nucleus', 'Cell wall presence', 'Type of DNA'],
            correct: 1,
            explanation: 'Eukaryotic cells have a true nucleus; prokaryotic cells do not.'
        }, {
            q: 'During which process does 1 cell divide to form 4 unique gametes?',
            options: ['Mitosis', 'Meiosis', 'Osmosis', 'Endocytosis'],
            correct: 1,
            explanation: 'Meiosis produces 4 non-identical gametes with half the chromosome number.'
        }];

        let quizAnswers = {};

        function renderQuiz() {
            const container = document.getElementById('quizContainer');
            container.innerHTML = '';
            quizData.forEach((item, idx) => {
                const div = document.createElement('div');
                div.className = 'quiz-item';
                div.innerHTML = `
                    <div class="q-text">${idx+1}. ${item.q}</div>
                    <div class="options">
                        ${item.options.map((opt, oi) => `
                            <label>
                                <input type="radio" name="q${idx}" value="${oi}" data-q="${idx}" data-opt="${oi}">
                                ${opt}
                            </label>
                        `).join('')}
                    </div>
                    <div class="feedback" id="feedback-${idx}"></div>
                `;
                container.appendChild(div);

                div.querySelectorAll('input[type="radio"]').forEach(radio => {
                    radio.addEventListener('change', function() {
                        const qIdx = parseInt(this.dataset.q);
                        const optVal = parseInt(this.dataset.opt);
                        quizAnswers[qIdx] = optVal;
                        checkQuiz();
                    });
                });
            });
            updateScore();
        }

        function checkQuiz() {
            let correct = 0;
            quizData.forEach((item, idx) => {
                const fb = document.getElementById(`feedback-${idx}`);
                const selected = quizAnswers[idx];
                const isCorrect = (selected === item.correct);
                if (selected !== undefined) {
                    fb.classList.add('show');
                    fb.classList.remove('correct', 'incorrect');
                    if (isCorrect) {
                        fb.classList.add('correct');
                        fb.innerHTML = `✅ Correct! ${item.explanation}`;
                        correct++;
                    } else {
                        fb.classList.add('incorrect');
                        fb.innerHTML = `❌ Oops! ${item.explanation}`;
                    }
                } else {
                    fb.classList.remove('show');
                }
            });
            document.getElementById('quizScore').textContent = `Score: ${correct} / ${quizData.length}`;
        }

        function updateScore() {
            let correct = 0;
            quizData.forEach((item, idx) => {
                if (quizAnswers[idx] === item.correct) correct++;
            });
            document.getElementById('quizScore').textContent = `Score: ${correct} / ${quizData.length}`;
        }

        // ─────────────────────────────────────────────────────────────
        // INIT
        // ─────────────────────────────────────────────────────────────
        document.addEventListener('DOMContentLoaded', function() {
            renderQuiz();
            navigateTo('page-dashboard');
        });

        const origNavigate = navigateTo;
        navigateTo = function(pageId) {
            origNavigate(pageId);
            if (pageId === 'page-exam') {
                updateScore();
            }
        };
    </script>
</body>
</html>
