            const label = document.getElementById('osmosisLabel');

            box.style.width = '140px';
            box.style.height = '140px';
            box.style.background = '#d4e8de';
            inner.style.width = '70%';
            inner.style.height = '70%';
            inner.style.background = '#b8d9c8';
            box.style.borderColor = '#0f5132';

            if (type === 'hypo') {
                box.style.width = '170px';
                box.style.height = '170px';
                box.style.background = '#c8e6d8';
                inner.style.width = '80%';
                inner.style.height = '80%';
                inner.style.background = '#a8d5ba';
                label.innerHTML = '💧 <strong>Hypotonic:</strong> Water enters the cell → cell swells (turgidity).';
                label.style.color = '#0a4a2a';
            } else if (type === 'iso') {
                box.style.width = '140px';
                box.style.height = '140px';
                box.style.background = '#d4e8de';
                inner.style.width = '70%';
                inner.style.height = '70%';
                inner.style.background = '#b8d9c8';
                label.innerHTML = '⚖️ <strong>Isotonic:</strong> Balanced water movement → cell stays normal.';
                label.style.color = '#0f5132';
            } else if (type === 'hyper') {
                box.style.width = '110px';
                box.style.height = '110px';
                box.style.background = '#f0d8d8';
                inner.style.width = '50%';
                inner.style.height = '50%';
                inner.style.background = '#dbb5b5';
                label.innerHTML = '🧂 <strong>Hypertonic:</strong> Water leaves the cell → cell shrinks (plasmolysis).';
                label.style.color = '#6b2e2e';
            }
        }

